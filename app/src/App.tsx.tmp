            )}
            
            <div className="flex gap-6 text-sm mt-8">
              <a href="#" className="text-slate hover:text-ivory transition-colors">{t('footer.rules')}</a>
              <a href="#" className="text-slate hover:text-ivory transition-colors">{t('footer.privacy')}</a>
            </div>
          </div>

          {/* Google Maps */}
          <div className="rounded-lg overflow-hidden border border-white/10 h-[300px] md:h-full min-h-[300px]">
            <iframe
              src={`https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2234.5!2d${CONFIG.business.coordinates.lng}!3d${CONFIG.business.coordinates.lat}!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x46e6e700415b8fa1%3A0xa1de19596e0d445e!2sZvaigzdziu%20Namai!5e0!3m2!1sen!2slt!4v1709577600000!5m2!1sen!2slt`}
              width="100%"
              height="100%"
              style={{ border: 0, filter: 'grayscale(30%) brightness(0.8)' }}
              allowFullScreen
              loading="lazy"
              referrerPolicy="no-referrer-when-downgrade"
              title="Location"
            />
          </div>
        </div>
        
        <p className="text-slate/50 text-xs mt-10 text-center">
          {t('footer.copyright')}
        </p>
      </div>
    </footer>
  );
};

// Booking Modal
const BookingModal = ({ 
  isOpen, 
  onClose,
  preselectedAccommodation
}: { 
  isOpen: boolean; 
  onClose: () => void;
  preselectedAccommodation?: string;
}) => {
  const { t, i18n } = useTranslation();
  const [step, setStep] = useState(1);
  const [bookingData, setBookingData] = useState<BookingData>({
    accommodationId: preselectedAccommodation || CONFIG.accommodations[0].id,
    checkIn: undefined,
    checkOut: undefined,
    guests: 2,
    name: '',
    email: '',
    phone: '',
    paymentMethod: 'card',
    activities: []
  });

  const selectedAcc = CONFIG.accommodations.find(a => a.id === bookingData.accommodationId);
  const nights = bookingData.checkIn && bookingData.checkOut 
    ? Math.ceil((bookingData.checkOut.getTime() - bookingData.checkIn.getTime()) / (1000 * 60 * 60 * 24))
    : 0;
  const totalPrice = selectedAcc && nights > 0 
    ? getCurrentPrice(selectedAcc.id, bookingData.checkIn) * nights
    : 0;

  const handleSubmit = () => {
    setStep(4);
    setTimeout(() => {
      onClose();
      setStep(1);
      setBookingData({
        accommodationId: CONFIG.accommodations[0].id,
        checkIn: undefined,
        checkOut: undefined,
        guests: 2,
        name: '',
        email: '',
        phone: '',
        paymentMethod: 'card',
        activities: []
      });
    }, 2000);
  };

  const toggleActivity = (activityId: string) => {
    setBookingData(prev => ({
      ...prev,
      activities: prev.activities.includes(activityId)
        ? prev.activities.filter(id => id !== activityId)
        : [...prev.activities, activityId]
    }));
  };

  return (
    <Dialog open={isOpen} onOpenChange={onClose}>
      <DialogContent className="bg-[#141B24] border-white/10 text-ivory max-w-lg max-h-[90vh] overflow-y-auto">
        <DialogHeader>
          <DialogTitle className="text-display text-xl text-ivory">
            {t('booking.title')} - {t(`booking.step${step}`)}
          </DialogTitle>
        </DialogHeader>

        {step === 1 && (
          <div className="space-y-6">
            <div>
              <Label className="text-slate mb-2 block">{t('nav.accommodation')}</Label>
              <Select 
                value={bookingData.accommodationId} 
                onValueChange={(v) => setBookingData({ ...bookingData, accommodationId: v })}
              >
                <SelectTrigger className="bg-[#0B0F17] border-white/10">
                  <SelectValue />
                </SelectTrigger>
                <SelectContent className="bg-[#0B0F17] border-white/10">
                  {CONFIG.accommodations.map(acc => (
                    <SelectItem key={acc.id} value={acc.id}>
                      {i18n.language === 'en' ? acc.nameEn : i18n.language === 'ru' ? acc.nameRu : acc.name}
                    </SelectItem>
                  ))}
                </SelectContent>
              </Select>
            </div>

            <div className="grid grid-cols-2 gap-4">
              <div>
                <Label className="text-slate mb-2 block">{t('booking.checkIn')}</Label>
                <CalendarComponent
                  mode="single"
                  selected={bookingData.checkIn}
                  onSelect={(date) => setBookingData({ ...bookingData, checkIn: date })}
                  className="bg-[#0B0F17] rounded-lg border border-white/10"
                  disabled={(date) => date < new Date()}
                />
              </div>
              <div>
                <Label className="text-slate mb-2 block">{t('booking.checkOut')}</Label>
                <CalendarComponent
                  mode="single"
                  selected={bookingData.checkOut}
                  onSelect={(date) => setBookingData({ ...bookingData, checkOut: date })}
                  className="bg-[#0B0F17] rounded-lg border border-white/10"
                  disabled={(date) => date < (bookingData.checkIn || new Date())}
                />
              </div>
            </div>

            <div>
              <Label className="text-slate mb-2 block">{t('booking.guests')}</Label>
              <Select 
                value={bookingData.guests.toString()} 
                onValueChange={(v) => setBookingData({ ...bookingData, guests: parseInt(v) })}
              >
                <SelectTrigger className="bg-[#0B0F17] border-white/10">
                  <SelectValue />
                </SelectTrigger>
                <SelectContent className="bg-[#0B0F17] border-white/10">
                  {[1,2,3,4].map(n => (
                    <SelectItem key={n} value={n.toString()}>
                      {n} {n === 1 ? t('booking.person') : t('booking.people')}
                    </SelectItem>
                  ))}
                </SelectContent>
              </Select>
            </div>

            {nights > 0 && (
              <div className="bg-[#0B0F17] rounded-lg p-4">
                <p className="text-slate text-sm">{nights} {t('booking.nights')} × {getCurrentPrice(bookingData.accommodationId, bookingData.checkIn)} €</p>
                <p className="text-gold font-bold text-lg">{t('booking.total')}: {totalPrice} €</p>
              </div>
            )}

            <Button 
              onClick={() => setStep(2)}
              disabled={!bookingData.checkIn || !bookingData.checkOut}
              className="w-full bg-gold text-[#0B0F17] hover:bg-gold/90"
            >
              {t('booking.next')} <ChevronRight className="w-4 h-4 ml-2" />
            </Button>
          </div>
        )}

        {step === 2 && (
          <div className="space-y-4">
            <div>
              <Label className="text-slate mb-2 block">{t('booking.name')}</Label>
              <Input 
                value={bookingData.name}
                onChange={(e) => setBookingData({ ...bookingData, name: e.target.value })}
                className="bg-[#0B0F17] border-white/10"
                placeholder="Jonas Jonaitis"
              />
            </div>
            <div>
              <Label className="text-slate mb-2 block">{t('booking.email')}</Label>
              <Input 
                type="email"
                value={bookingData.email}
                onChange={(e) => setBookingData({ ...bookingData, email: e.target.value })}
                className="bg-[#0B0F17] border-white/10"
                placeholder="jonas@pastas.lt"
              />
            </div>
            <div>
              <Label className="text-slate mb-2 block">{t('booking.phone')}</Label>
              <Input 
                type="tel"
                value={bookingData.phone}
                onChange={(e) => setBookingData({ ...bookingData, phone: e.target.value })}
                className="bg-[#0B0F17] border-white/10"
                placeholder="+370 600 00000"
              />
            </div>
            <div>
              <Label className="text-slate mb-2 block">{t('booking.paymentMethod')}</Label>
              <Select 
                value={bookingData.paymentMethod} 
                onValueChange={(v) => setBookingData({ ...bookingData, paymentMethod: v })}
              >
                <SelectTrigger className="bg-[#0B0F17] border-white/10">
                  <SelectValue />
                </SelectTrigger>
                <SelectContent className="bg-[#0B0F17] border-white/10">
                  {CONFIG.paymentMethods.map(pm => (
                    <SelectItem key={pm.id} value={pm.id}>
                      {i18n.language === 'en' ? pm.nameEn : i18n.language === 'ru' ? pm.nameRu : pm.name}
                    </SelectItem>
                  ))}
                </SelectContent>
              </Select>
            </div>

            <div>
              <Label className="text-slate mb-2 block">{t('nav.activities')} ({t('common.optional')})</Label>
              <div className="space-y-2">
                {CONFIG.activities.map(activity => (
                  <label key={activity.id} className="flex items-center gap-3 p-3 bg-[#0B0F17] rounded-lg cursor-pointer hover:bg-white/5 transition-colors">
                    <input
                      type="checkbox"
                      checked={bookingData.activities.includes(activity.id)}
                      onChange={() => toggleActivity(activity.id)}
                      className="w-4 h-4 accent-gold"
                    />
                    <span className="text-ivory text-sm flex-1">
                      {i18n.language === 'en' ? activity.nameEn : i18n.language === 'ru' ? activity.nameRu : activity.name}
                    </span>
                    <span className="text-gold text-sm">+{activity.price} €</span>
                  </label>
                ))}
              </div>
            </div>

            <div className="flex gap-3">
              <Button 
                onClick={() => setStep(1)}
                variant="outline"
                className="flex-1 border-white/10"
              >
                {t('booking.back')}
              </Button>
              <Button 
                onClick={() => setStep(3)}
                disabled={!bookingData.name || !bookingData.email}
                className="flex-1 bg-gold text-[#0B0F17] hover:bg-gold/90"
              >
                {t('booking.next')}
              </Button>
            </div>
          </div>
        )}

        {step === 3 && (
          <div className="space-y-4">
            <div className="bg-[#0B0F17] rounded-lg p-4 space-y-2">
              <div className="flex justify-between">
                <span className="text-slate">{t('nav.accommodation')}:</span>
                <span className="text-ivory">
                  {selectedAcc && (i18n.language === 'en' ? selectedAcc.nameEn : i18n.language === 'ru' ? selectedAcc.nameRu : selectedAcc.name)}
                </span>
              </div>
              <div className="flex justify-between">
                <span className="text-slate">{t('booking.checkIn')}:</span>
                <span className="text-ivory">{bookingData.checkIn?.toLocaleDateString()}</span>
              </div>
              <div className="flex justify-between">
                <span className="text-slate">{t('booking.checkOut')}:</span>
                <span className="text-ivory">{bookingData.checkOut?.toLocaleDateString()}</span>
              </div>
              <div className="flex justify-between">
                <span className="text-slate">{t('booking.guests')}:</span>
                <span className="text-ivory">{bookingData.guests}</span>
              </div>
              {bookingData.activities.length > 0 && (
                <div className="border-t border-white/10 pt-2 mt-2">
                  <span className="text-slate block mb-1">{t('nav.activities')}:</span>
                  {bookingData.activities.map(actId => {
                    const act = CONFIG.activities.find(a => a.id === actId);
                    return act ? (
                      <span key={actId} className="text-ivory text-sm block">
                        + {i18n.language === 'en' ? act.nameEn : i18n.language === 'ru' ? act.nameRu : act.name}
                      </span>
                    ) : null;
                  })}
                </div>
              )}
              <div className="border-t border-white/10 pt-2 mt-2">
                <div className="flex justify-between">
                  <span className="text-slate">{t('booking.total')}:</span>
                  <span className="text-gold font-bold text-lg">
                    {totalPrice + bookingData.activities.reduce((sum, actId) => {
                      const act = CONFIG.activities.find(a => a.id === actId);
                      return sum + (act?.price || 0);
                    }, 0)} €
                  </span>
                </div>
              </div>
            </div>
            <div className="flex gap-3">
              <Button 
                onClick={() => setStep(2)}
                variant="outline"
                className="flex-1 border-white/10"
              >
                {t('booking.back')}
              </Button>
              <Button 
                onClick={handleSubmit}
                className="flex-1 bg-gold text-[#0B0F17] hover:bg-gold/90"
              >
                {t('booking.confirm')}
              </Button>
            </div>
          </div>
        )}

        {step === 4 && (
          <div className="text-center py-8">
            <div className="w-16 h-16 bg-gold/20 rounded-full flex items-center justify-center mx-auto mb-4">
              <Check className="w-8 h-8 text-gold" />
            </div>
            <p className="text-ivory text-lg mb-2">{t('booking.success')}</p>
            <p className="text-slate">{t('booking.successMessage', { email: bookingData.email })}</p>
          </div>
        )}
      </DialogContent>
    </Dialog>
  );
};

// Admin Dashboard Modal
const AdminModal = ({ isOpen, onClose }: { isOpen: boolean; onClose: () => void }) => {
  const { t, i18n } = useTranslation();
  const [isLoggedIn, setIsLoggedIn] = useState(false);
  const [password, setPassword] = useState('');
  const [activeTab, setActiveTab] = useState('prices');
  const [config, setConfig] = useState(CONFIG);

  const handleLogin = () => {
    if (password === CONFIG.admin.password) {
      setIsLoggedIn(true);
    }
  };

  const updateAccommodationPrice = (id: string, field: string, value: number) => {
    setConfig(prev => ({
      ...prev,
      accommodations: prev.accommodations.map(acc => 
        acc.id === id ? { ...acc, [field]: value } : acc
      )
    }));
  };

  const updateActivityPrice = (id: string, value: number) => {
    setConfig(prev => ({
      ...prev,
      activities: prev.activities.map(act => 
        act.id === id ? { ...act, price: value } : act
      )
    }));
  };

  if (!isLoggedIn) {
    return (
      <Dialog open={isOpen} onOpenChange={onClose}>
        <DialogContent className="bg-[#141B24] border-white/10 text-ivory max-w-md">
          <DialogHeader>
            <DialogTitle className="text-display text-xl text-ivory">{t('admin.login')}</DialogTitle>
          </DialogHeader>
          <div className="space-y-4">
            <div>
              <Label className="text-slate mb-2 block">{t('admin.password')}</Label>
              <Input 
                type="password"
                value={password}
                onChange={(e) => setPassword(e.target.value)}
                className="bg-[#0B0F17] border-white/10"
                onKeyDown={(e) => e.key === 'Enter' && handleLogin()}
              />
            </div>
            <Button 
              onClick={handleLogin}
              className="w-full bg-gold text-[#0B0F17] hover:bg-gold/90"
            >
              {t('admin.login')}
            </Button>
          </div>
        </DialogContent>
      </Dialog>
    );
  }

  return (
    <Dialog open={isOpen} onOpenChange={onClose}>
      <DialogContent className="bg-[#141B24] border-white/10 text-ivory max-w-3xl max-h-[90vh] overflow-y-auto">
        <DialogHeader>
          <DialogTitle className="text-display text-xl text-ivory flex items-center justify-between">
            {t('admin.title')}
            <Button onClick={() => { setIsLoggedIn(false); onClose(); }} variant="outline" size="sm" className="border-white/10">
              {t('admin.logout')}
            </Button>
          </DialogTitle>
        </DialogHeader>

        <Tabs value={activeTab} onValueChange={setActiveTab}>
          <TabsList className="bg-[#0B0F17] border border-white/10">
            <TabsTrigger value="prices" className="data-[state=active]:bg-gold data-[state=active]:text-[#0B0F17]">
              <Settings className="w-4 h-4 mr-2" /> {t('admin.prices')}
            </TabsTrigger>
            <TabsTrigger value="activities" className="data-[state=active]:bg-gold data-[state=active]:text-[#0B0F17]">
              <Edit3 className="w-4 h-4 mr-2" /> {t('admin.activities')}
            </TabsTrigger>
          </TabsList>

          <TabsContent value="prices" className="space-y-6">
            <h3 className="text-lg font-semibold text-ivory">{t('accommodation.title')}</h3>
            {config.accommodations.map(acc => (
              <div key={acc.id} className="bg-[#0B0F17] rounded-lg p-4 space-y-3">
                <h4 className="text-ivory font-medium">
                  {i18n.language === 'en' ? acc.nameEn : i18n.language === 'ru' ? acc.nameRu : acc.name}
                </h4>
                <div className="grid grid-cols-3 gap-4">
                  <div>
                    <Label className="text-slate text-xs">Žemasis sezonas</Label>
                    <Input 
                      type="number"
                      value={acc.priceLowSeason}
                      onChange={(e) => updateAccommodationPrice(acc.id, 'priceLowSeason', parseInt(e.target.value))}
                      className="bg-[#141B24] border-white/10 mt-1"
                    />
                  </div>
                  <div>
                    <Label className="text-slate text-xs">Aukštasis sezonas</Label>
                    <Input 
                      type="number"
                      value={acc.priceHighSeason}
                      onChange={(e) => updateAccommodationPrice(acc.id, 'priceHighSeason', parseInt(e.target.value))}
                      className="bg-[#141B24] border-white/10 mt-1"
                    />
                  </div>
                  <div>
                    <Label className="text-slate text-xs">Savaitgalis</Label>
                    <Input 
                      type="number"
                      value={acc.priceWeekend}
                      onChange={(e) => updateAccommodationPrice(acc.id, 'priceWeekend', parseInt(e.target.value))}
                      className="bg-[#141B24] border-white/10 mt-1"
                    />
                  </div>
                </div>
              </div>
            ))}
            <Button 
              onClick={() => alert('Išsaugota! (Demo)')}
              className="w-full bg-gold text-[#0B0F17] hover:bg-gold/90"
            >
              {t('admin.save')}
            </Button>
          </TabsContent>

          <TabsContent value="activities" className="space-y-4">
            <h3 className="text-lg font-semibold text-ivory">{t('activities.title')}</h3>
            {config.activities.map(act => (
              <div key={act.id} className="bg-[#0B0F17] rounded-lg p-4 flex items-center justify-between">
                <div>
                  <h4 className="text-ivory font-medium">
                    {i18n.language === 'en' ? act.nameEn : i18n.language === 'ru' ? act.nameRu : act.name}
                  </h4>
                  <p className="text-slate text-sm">{act.duration}</p>
                </div>
                <div className="flex items-center gap-2">
                  <Input 
                    type="number"
                    value={act.price}
                    onChange={(e) => updateActivityPrice(act.id, parseInt(e.target.value))}
                    className="bg-[#141B24] border-white/10 w-24"
                  />
                  <span className="text-slate">€</span>
                </div>
              </div>
            ))}
            <Button 
              onClick={() => alert('Išsaugota! (Demo)')}
              className="w-full bg-gold text-[#0B0F17] hover:bg-gold/90"
            >
              {t('admin.save')}
            </Button>
          </TabsContent>
        </Tabs>
      </DialogContent>
    </Dialog>
  );
};

// Main App
function App() {
  const [isBookingOpen, setIsBookingOpen] = useState(false);
  const [isAdminOpen, setIsAdminOpen] = useState(false);
  const [preselectedAccommodation, setPreselectedAccommodation] = useState<string | undefined>();
  const { t } = useTranslation();
  const mainRef = useRef<HTMLDivElement>(null);

  useEffect(() => {
    const setupSnap = () => {
      const pinned = ScrollTrigger.getAll()
        .filter(st => st.vars.pin)
        .sort((a, b) => a.start - b.start);
      
      const maxScroll = ScrollTrigger.maxScroll(window);
      if (!maxScroll || pinned.length === 0) return;

      const pinnedRanges = pinned.map(st => ({
        start: st.start / maxScroll,
        end: (st.end ?? st.start) / maxScroll,
        center: (st.start + ((st.end ?? st.start) - st.start) * 0.5) / maxScroll,
      }));

      ScrollTrigger.create({
        snap: {
          snapTo: (value: number) => {
            const inPinned = pinnedRanges.some(r => value >= r.start - 0.02 && value <= r.end + 0.02);
            if (!inPinned) return value;
            
            const target = pinnedRanges.reduce((closest, r) =>
              Math.abs(r.center - value) < Math.abs(closest - value) ? r.center : closest,
              pinnedRanges[0]?.center ?? 0
            );
            return target;
          },
          duration: { min: 0.15, max: 0.35 },
          delay: 0,
          ease: 'power2.out'
        }
      });
    };

    const timer = setTimeout(setupSnap, 500);
    
    return () => {
      clearTimeout(timer);
      ScrollTrigger.getAll().forEach(st => st.kill());
    };
  }, []);

  const openBooking = (accommodationId?: string) => {
    setPreselectedAccommodation(accommodationId);
    setIsBookingOpen(true);
  };

  return (
    <div ref={mainRef} className="relative bg-primary-navy">
      <div className="grain-overlay" />
      
      <Navigation onAdminClick={() => setIsAdminOpen(true)} />
      
      <HeroSection onBookClick={() => openBooking()} />
      
      <PinnedSection
        id="what"
        backgroundImage="/what_dome_sky.jpg"
        headline={t('sections.what.title')}
        body={t('sections.what.body')}
        fabLabel={t('sections.what.cta')}
        onFabClick={() => openBooking()}
        zIndex={20}
      />
      
      <PinnedSection
        id="where"
        backgroundImage="/where_lake_shore.jpg"
        headline={t('sections.where.title')}
        body={t('sections.where.body')}
        fabLabel={t('sections.where.cta')}
        onFabClick={() => document.getElementById('contact')?.scrollIntoView({ behavior: 'smooth' })}
        zIndex={30}
      />
      
      <PinnedSection
        id="why"
        backgroundImage="/why_dome_interior.jpg"
        headline={t('sections.why.title')}
        body={t('sections.why.body')}
        fabLabel={t('sections.why.cta')}
        onFabClick={() => document.getElementById('activities')?.scrollIntoView({ behavior: 'smooth' })}
        zIndex={40}
      />
      
      <PinnedSection
        id="for-whom"
        backgroundImage="/for_whom_couple_lake.jpg"
        headline={t('sections.forWhom.title')}
        body={t('sections.forWhom.body')}
        fabLabel={t('sections.forWhom.cta')}
        onFabClick={() => openBooking()}
        zIndex={50}
      />
      
      <PinnedSection
        id="amenities"
        backgroundImage="/amenities_dome_interior.jpg"
        headline={t('sections.amenities.title')}
        body={t('sections.amenities.body')}
        fabLabel={t('sections.amenities.cta')}
        onFabClick={() => document.getElementById('accommodation')?.scrollIntoView({ behavior: 'smooth' })}
        zIndex={60}
      />
      
      <PinnedSection
        id="pricing"
        backgroundImage="/pricing_dome_night.jpg"
        headline={t('sections.pricing.title', { price: 100 })}
        body={t('sections.pricing.body')}
        fabLabel={t('sections.pricing.cta')}
        onFabClick={() => openBooking()}
        zIndex={70}
      />
      
      <PinnedSection
        id="availability"
        backgroundImage="/availability_starry_sky.jpg"
        headline={t('sections.availability.title')}
        body={t('sections.availability.body')}
        fabLabel={t('sections.availability.cta')}
        onFabClick={() => openBooking()}
        zIndex={80}
      />
      
      <PinnedSection
        id="booking-cta"
        backgroundImage="/booking_dome_dusk.jpg"
        headline={t('sections.booking.title')}
        body={t('sections.booking.body')}
        fabLabel={t('sections.booking.cta')}
        onFabClick={() => openBooking()}
        zIndex={90}
      />
      
      <PinnedSection
        id="planetarium"
        backgroundImage="/planetarium_stars.jpg"
        headline={t('sections.planetarium.title')}
        body={t('sections.planetarium.body')}
        fabLabel={t('sections.planetarium.cta')}
        onFabClick={() => openBooking()}
        zIndex={100}
      />
      
      <AccommodationSection onBookClick={openBooking} />
      <ActivitiesSection />
      <TestimonialsSection onBookClick={() => openBooking()} />
      <FooterSection onBookClick={() => openBooking()} />
      
      <BookingModal 
        isOpen={isBookingOpen} 
        onClose={() => setIsBookingOpen(false)}
        preselectedAccommodation={preselectedAccommodation}
      />
      
      <AdminModal isOpen={isAdminOpen} onClose={() => setIsAdminOpen(false)} />
    </div>
  );
}

export default App;
