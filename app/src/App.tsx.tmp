// Types
interface BookingData {
  accommodationId: string;
  checkIn: Date | undefined;
  checkOut: Date | undefined;
  guests: number;
  name: string;
  email: string;
  phone: string;
  paymentMethod: string;
  activities: string[];
}

// Language Switcher
const LanguageSwitcher = () => {
  const { i18n } = useTranslation();
  const [isOpen, setIsOpen] = useState(false);

  const changeLanguage = (code: string) => {
    i18n.changeLanguage(code);
    setIsOpen(false);
  };

  return (
    <div className="relative">
      <button
        onClick={() => setIsOpen(!isOpen)}
        className="flex items-center gap-2 text-slate hover:text-ivory transition-colors"
      >
        <Globe className="w-4 h-4" />
        <span className="text-micro">{i18n.language.toUpperCase()}</span>
      </button>
      
      {isOpen && (
        <div className="absolute right-0 top-full mt-2 bg-[#141B24] border border-white/10 rounded-lg overflow-hidden z-50">
          {languages.map((lang) => (
            <button
              key={lang.code}
              onClick={() => changeLanguage(lang.code)}
              className={`block w-full px-4 py-2 text-left text-sm hover:bg-white/5 transition-colors ${
                i18n.language === lang.code ? 'text-gold' : 'text-ivory'
              }`}
            >
              {lang.flag} {lang.name}
            </button>
          ))}
        </div>
      )}
    </div>
  );
};

// Pinned Section Component
interface PinnedSectionProps {
  id: string;
  backgroundImage: string;
  headline: string;
  body: string;
  fabLabel: string;
  onFabClick: () => void;
  zIndex: number;
}

const PinnedSection = ({ 
  id, 
  backgroundImage, 
  headline, 
  body, 
  fabLabel, 
  onFabClick, 
  zIndex 
}: PinnedSectionProps) => {
  const sectionRef = useRef<HTMLDivElement>(null);
  const bgRef = useRef<HTMLDivElement>(null);
  const headlineRef = useRef<HTMLHeadingElement>(null);
  const bodyRef = useRef<HTMLParagraphElement>(null);
  const fabRef = useRef<HTMLButtonElement>(null);

  useEffect(() => {
    const section = sectionRef.current;
    const bg = bgRef.current;
    const headlineEl = headlineRef.current;
    const bodyEl = bodyRef.current;
    const fab = fabRef.current;

    if (!section || !bg || !headlineEl || !bodyEl || !fab) return;

    const ctx = gsap.context(() => {
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: 'top top',
          end: '+=130%',
          pin: true,
          scrub: 0.6,
          onLeaveBack: () => {
            gsap.set([headlineEl, bodyEl, fab], { opacity: 1, x: 0, y: 0 });
            gsap.set(bg, { scale: 1, y: 0, opacity: 1 });
          }
        }
      });

      tl.fromTo(bg, 
        { scale: 1.10, opacity: 0.6 },
        { scale: 1, opacity: 1, ease: 'none' },
        0
      );
      
      tl.fromTo(headlineEl,
        { x: '-50vw', opacity: 0 },
        { x: 0, opacity: 1, ease: 'power2.out' },
        0
      );
      
      tl.fromTo(bodyEl,
        { y: '10vh', opacity: 0 },
        { y: 0, opacity: 1, ease: 'power2.out' },
        0.05
      );
      
      tl.fromTo(fab,
        { x: '20vw', opacity: 0, scale: 0.9 },
        { x: 0, opacity: 1, scale: 1, ease: 'back.out(1.6)' },
        0.10
      );

      tl.to(headlineEl,
        { x: '18vw', opacity: 0, ease: 'power2.in' },
        0.70
      );
      
      tl.to(bodyEl,
        { y: '-8vh', opacity: 0, ease: 'power2.in' },
        0.70
      );
      
      tl.to(fab,
        { x: '14vw', opacity: 0, ease: 'power2.in' },
        0.70
      );
      
      tl.to(bg,
        { scale: 1.06, y: '-6vh', opacity: 0, ease: 'power2.in' },
        0.70
      );
    }, section);

    return () => ctx.revert();
  }, []);

  return (
    <section 
      ref={sectionRef}
      id={id}
      className="section-pinned"
      style={{ zIndex }}
    >
      <div 
        ref={bgRef}
        className="absolute inset-0 w-full h-full"
        style={{
          backgroundImage: `url(${backgroundImage})`,
          backgroundSize: 'cover',
          backgroundPosition: 'center',
        }}
      />
      <div className="vignette-overlay absolute inset-0" />
      
      <div className="absolute left-[7vw] top-[60vh] w-[74vw] max-w-4xl">
        <h2 
          ref={headlineRef}
          className="text-display text-ivory text-[clamp(32px,4.2vw,64px)] mb-6 will-change-transform"
        >
          {headline}
        </h2>
        <p 
          ref={bodyRef}
          className="text-slate text-[clamp(14px,1.2vw,18px)] leading-relaxed max-w-2xl will-change-transform"
        >
          {body}
        </p>
      </div>
      
      <button
        ref={fabRef}
        onClick={onFabClick}
        className="fab-button absolute right-[4vw] bottom-[5vh] will-change-transform"
      >
        <span className="text-gold text-xs font-semibold uppercase tracking-wider">{fabLabel}</span>
      </button>
    </section>
  );
};

// Hero Section
const HeroSection = ({ onBookClick }: { onBookClick: () => void }) => {
  const { t } = useTranslation();
  const sectionRef = useRef<HTMLDivElement>(null);
  const bgRef = useRef<HTMLDivElement>(null);
  const labelRef = useRef<HTMLSpanElement>(null);
  const headlineRef = useRef<HTMLHeadingElement>(null);
  const subheadRef = useRef<HTMLParagraphElement>(null);
  const fabRef = useRef<HTMLButtonElement>(null);

  useEffect(() => {
    const section = sectionRef.current;
    const bg = bgRef.current;
    const label = labelRef.current;
    const headline = headlineRef.current;
    const subhead = subheadRef.current;
    const fab = fabRef.current;

    if (!section || !bg || !label || !headline || !subhead || !fab) return;

    const entranceTl = gsap.timeline({ delay: 0.2 });
    
    entranceTl.fromTo(bg,
      { scale: 1.08, opacity: 0 },
      { scale: 1, opacity: 1, duration: 1.0, ease: 'power2.out' }
    );
    
    entranceTl.fromTo(label,
      { y: -10, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.6, ease: 'power2.out' },
      '-=0.6'
    );
    
    entranceTl.fromTo(headline,
      { y: 28, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.9, ease: 'power2.out' },
      '-=0.4'
    );
    
    entranceTl.fromTo(subhead,
      { y: 14, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.7, ease: 'power2.out' },
      '-=0.5'
    );
    
    entranceTl.fromTo(fab,
      { scale: 0.85, opacity: 0 },
      { scale: 1, opacity: 1, duration: 0.6, ease: 'back.out(1.6)' },
      '-=0.4'
    );

    const ctx = gsap.context(() => {
      gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: 'top top',
          end: '+=130%',
          scrub: 0.6,
          onLeaveBack: () => {
            gsap.set([label, headline, subhead, fab], { opacity: 1, x: 0, y: 0 });
            gsap.set(bg, { scale: 1, y: 0 });
          }
        }
      })
      .to([label, headline, subhead], 
        { y: '-18vh', opacity: 0, ease: 'power2.in' },
        0.70
      )
      .to(bg,
        { scale: 1.06, y: '-6vh', ease: 'power2.in' },
        0.70
      )
      .to(fab,
        { x: '12vw', opacity: 0, ease: 'power2.in' },
        0.70
      );
    }, section);

    return () => {
      entranceTl.kill();
      ctx.revert();
    };
  }, []);

  return (
    <section 
      ref={sectionRef}
      className="section-pinned"
      style={{ zIndex: 10 }}
    >
      <div 
        ref={bgRef}
        className="absolute inset-0 w-full h-full"
        style={{
          backgroundImage: 'url(/hero_dome_stars.jpg)',
          backgroundSize: 'cover',
          backgroundPosition: 'center 60%',
        }}
      />
      <div className="vignette-overlay absolute inset-0" />
      
      <div className="absolute left-[7vw] top-[58vh] w-[62vw] max-w-4xl">
        <span 
          ref={labelRef}
          className="text-micro text-gold block mb-4 will-change-transform"
        >
          {t('hero.label')}
        </span>
        <h1 
          ref={headlineRef}
          className="text-display text-ivory text-[clamp(44px,5.2vw,84px)] mb-6 will-change-transform"
        >
          {t('hero.title')}
        </h1>
        <p 
          ref={subheadRef}
          className="text-slate text-[clamp(14px,1.2vw,18px)] leading-relaxed max-w-xl will-change-transform"
        >
          {t('hero.subtitle')}
        </p>
      </div>
      
      <button
        ref={fabRef}
        onClick={onBookClick}
        className="fab-button absolute right-[4vw] bottom-[5vh] will-change-transform"
      >
        <span className="text-gold text-xs font-semibold uppercase tracking-wider">{t('hero.cta')}</span>
      </button>
    </section>
  );
};

// Navigation Component
const Navigation = ({ onAdminClick }: { onAdminClick: () => void }) => {
  const [scrolled, setScrolled] = useState(false);
  const { t } = useTranslation();

  useEffect(() => {
    const handleScroll = () => {
      setScrolled(window.scrollY > 100);
    };
    window.addEventListener('scroll', handleScroll, { passive: true });
    return () => window.removeEventListener('scroll', handleScroll);
  }, []);

  const scrollToSection = (id: string) => {
    const element = document.getElementById(id);
    if (element) {
      element.scrollIntoView({ behavior: 'smooth' });
    }
  };

  return (
    <nav 
      className={`fixed top-0 left-0 right-0 z-50 transition-all duration-500 ${
        scrolled ? 'bg-[#0B0F17]/90 backdrop-blur-md py-4' : 'py-6'
      }`}
    >
      <div className="flex items-center justify-between px-[4vw]">
        <span className="text-micro text-ivory tracking-[0.18em]">
          {CONFIG.business.name.toUpperCase()}
        </span>
        <div className="hidden md:flex items-center gap-8">
          <button 
            onClick={() => scrollToSection('accommodation')}
            className="text-micro text-slate hover:text-ivory transition-colors"
          >
            {t('nav.accommodation')}
          </button>
          <button 
            onClick={() => scrollToSection('activities')}
            className="text-micro text-slate hover:text-ivory transition-colors"
          >
            {t('nav.activities')}
          </button>
          <button 
            onClick={() => scrollToSection('contact')}
            className="text-micro text-slate hover:text-ivory transition-colors"
          >
            {t('nav.contact')}
          </button>
          <LanguageSwitcher />
          <button 
            onClick={onAdminClick}
            className="text-micro text-slate hover:text-gold transition-colors"
          >
            <Lock className="w-4 h-4" />
          </button>
        </div>
      </div>
    </nav>
  );
};

// Testimonials Section
const TestimonialsSection = ({ onBookClick }: { onBookClick: () => void }) => {
  const { t } = useTranslation();
  const sectionRef = useRef<HTMLDivElement>(null);
  const titleRef = useRef<HTMLHeadingElement>(null);
  const cardsRef = useRef<HTMLDivElement>(null);

  useEffect(() => {
    const section = sectionRef.current;
    const title = titleRef.current;
    const cards = cardsRef.current;

    if (!section || !title || !cards) return;

    const ctx = gsap.context(() => {
      gsap.fromTo(title,
        { y: 24, opacity: 0 },
        {
          y: 0, opacity: 1,
          scrollTrigger: {
            trigger: section,
            start: 'top 80%',
            end: 'top 55%',
            scrub: true
          }
        }
      );

      const cardElements = cards.querySelectorAll('.testimonial-card');
      gsap.fromTo(cardElements,
        { y: 40, opacity: 0 },
        {
          y: 0, opacity: 1, stagger: 0.1,
          scrollTrigger: {
            trigger: cards,
            start: 'top 70%',
            end: 'top 40%',
            scrub: true
          }
        }
      );
    }, section);

    return () => ctx.revert();
  }, []);

  const testimonials = [
    { text: 'Nerealu žiūrėti į žvaigždes gulint šiltoje lovoje.', author: 'Greta & Tomas' },
    { text: 'Planetariumo seansas vidurnaktį—magija.', author: 'Eglė' },
    { text: 'Ramybė, kurią sunkiai randi kitur.', author: 'Mantas' }
  ];

  return (
    <section 
      ref={sectionRef}
      id="testimonials"
      className="bg-secondary-navy py-[10vh] px-6"
      style={{ zIndex: 110 }}
    >
      <div className="max-w-[980px] mx-auto">
        <h2 
          ref={titleRef}
          className="text-display text-ivory text-[clamp(28px,3.5vw,48px)] text-center mb-12 will-change-transform"
        >
          {t('testimonials.title')}
        </h2>
        
        <div ref={cardsRef} className="grid md:grid-cols-3 gap-6">
          {testimonials.map((item, i) => (
            <div 
              key={i}
              className="testimonial-card bg-[#0B0F17]/60 backdrop-blur-sm rounded-lg p-6 border border-white/5 will-change-transform"
            >
              <Star className="w-5 h-5 text-gold mb-4" />
              <p className="text-ivory text-lg mb-4 leading-relaxed">"{item.text}"</p>
              <p className="text-slate text-sm">— {item.author}</p>
            </div>
          ))}
        </div>
        
        <div className="text-center mt-10">
          <Button 
            onClick={onBookClick}
            className="bg-gold text-[#0B0F17] hover:bg-gold/90 px-8 py-3 rounded-full font-semibold"
          >
            {t('footer.cta')}
          </Button>
        </div>
      </div>
    </section>
  );
};

// Activities Section
const ActivitiesSection = () => {
  const { t, i18n } = useTranslation();
  const sectionRef = useRef<HTMLDivElement>(null);

  useEffect(() => {
    const section = sectionRef.current;
    if (!section) return;

    const ctx = gsap.context(() => {
      const items = section.querySelectorAll('.activity-item');
      gsap.fromTo(items,
        { y: 30, opacity: 0 },
        {
          y: 0, opacity: 1, stagger: 0.1,
          scrollTrigger: {
            trigger: section,
            start: 'top 70%',
            end: 'top 40%',
            scrub: true
          }
        }
      );
    }, section);

    return () => ctx.revert();
  }, []);

  const getActivityName = (activity: typeof CONFIG.activities[0]) => {
    if (i18n.language === 'en') return activity.nameEn;
    if (i18n.language === 'ru') return activity.nameRu;
    return activity.name;
  };

  const getActivityDesc = (activity: typeof CONFIG.activities[0]) => {
    if (i18n.language === 'en') return activity.descriptionEn;
    if (i18n.language === 'ru') return activity.descriptionRu;
    return activity.description;
  };

  const getActivityDuration = (activity: typeof CONFIG.activities[0]) => {
    if (i18n.language === 'en') return activity.durationEn;
    if (i18n.language === 'ru') return activity.durationRu;
    return activity.duration;
  };

  const iconMap: Record<string, React.ElementType> = {
    Star, Flame, Droplets, Utensils
  };

  return (
    <section 
      ref={sectionRef}
      id="activities"
      className="bg-primary-navy py-[10vh] px-6"
      style={{ zIndex: 105 }}
    >
      <div className="max-w-[1200px] mx-auto">
        <h2 className="text-display text-ivory text-[clamp(28px,3.5vw,48px)] text-center mb-4">
          {t('activities.title')}
        </h2>
        <p className="text-slate text-center mb-12 max-w-xl mx-auto">
          {t('activities.subtitle')}
        </p>
        
        <div className="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {CONFIG.activities.map((activity, i) => {
            const Icon = iconMap[activity.icon] || Star;
            return (
              <div 
                key={i}
                className="activity-item group bg-[#141B24] rounded-lg p-6 border border-white/5 hover:border-gold/30 transition-all will-change-transform"
              >
                <Icon className="w-8 h-8 text-gold mb-4 group-hover:scale-110 transition-transform" />
                <h3 className="text-ivory font-semibold text-lg mb-2">{getActivityName(activity)}</h3>
                <p className="text-slate text-sm mb-4">{getActivityDesc(activity)}</p>
                <div className="flex justify-between items-center text-sm">
                  <span className="text-gold font-semibold">{activity.price} €</span>
                  <span className="text-slate">{getActivityDuration(activity)}</span>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>
  );
};

// Accommodation Section
const AccommodationSection = ({ onBookClick }: { onBookClick: (id: string) => void }) => {
  const { t, i18n } = useTranslation();
  const sectionRef = useRef<HTMLDivElement>(null);

  useEffect(() => {
    const section = sectionRef.current;
    if (!section) return;

    const ctx = gsap.context(() => {
      const cards = section.querySelectorAll('.accommodation-card');
      gsap.fromTo(cards,
        { y: 40, opacity: 0 },
        {
          y: 0, opacity: 1, stagger: 0.15,
          scrollTrigger: {
            trigger: section,
            start: 'top 70%',
            end: 'top 30%',
            scrub: true
          }
        }
      );
    }, section);

    return () => ctx.revert();
  }, []);

  const getAccName = (acc: typeof CONFIG.accommodations[0]) => {
    if (i18n.language === 'en') return acc.nameEn;
    if (i18n.language === 'ru') return acc.nameRu;
    return acc.name;
  };

  const getAccDesc = (acc: typeof CONFIG.accommodations[0]) => {
    if (i18n.language === 'en') return acc.descriptionEn;
    if (i18n.language === 'ru') return acc.descriptionRu;
    return acc.description;
  };

  const getAccFeatures = (acc: typeof CONFIG.accommodations[0]) => {
    if (i18n.language === 'en') return acc.featuresEn;
    if (i18n.language === 'ru') return acc.featuresRu;
    return acc.features;
  };

  return (
    <section 
      ref={sectionRef}
      id="accommodation"
      className="bg-primary-navy py-[10vh] px-6"
      style={{ zIndex: 100 }}
    >
      <div className="max-w-[1200px] mx-auto">
        <h2 className="text-display text-ivory text-[clamp(28px,3.5vw,48px)] text-center mb-4">
          {t('accommodation.title')}
        </h2>
        <p className="text-slate text-center mb-12 max-w-xl mx-auto">
          {t('accommodation.subtitle')}
        </p>
        
        <div className="grid md:grid-cols-2 gap-6">
          {CONFIG.accommodations.map((acc, i) => (
            <div 
              key={i}
              className="accommodation-card bg-[#141B24] rounded-lg overflow-hidden border border-white/5 hover:border-gold/30 transition-all will-change-transform group"
            >
              <div className="h-48 overflow-hidden">
                <img 
                  src={acc.image} 
                  alt={getAccName(acc)}
                  className="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              </div>
              <div className="p-6">
                <h3 className="text-ivory font-bold text-xl mb-2">{getAccName(acc)}</h3>
                <p className="text-slate text-sm mb-4">{getAccDesc(acc)}</p>
                <div className="flex items-center gap-4 mb-4 text-sm">
                  <span className="text-gold flex items-center gap-1">
                    <Users className="w-4 h-4" /> {t('accommodation.capacity', { count: acc.capacity })}
                  </span>
                  <span className="text-ivory font-semibold">
                    {t('accommodation.perNight')}: {acc.priceLowSeason}-{acc.priceHighSeason} €
                  </span>
                </div>
                <div className="flex flex-wrap gap-2 mb-4">
                  {getAccFeatures(acc).slice(0, 4).map((feature, fi) => (
                    <span key={fi} className="text-xs bg-[#0B0F17] text-slate px-2 py-1 rounded">
                      {feature}
                    </span>
                  ))}
                </div>
                <Button 
                  onClick={() => onBookClick(acc.id)}
                  className="w-full bg-gold text-[#0B0F17] hover:bg-gold/90"
                >
                  {t('accommodation.bookNow')}
                </Button>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  );
};

